  "keyFeatures": [
    "FHRR (Holographic Reduced Representation) fact memory — millisecond algebraic recall without embeddings or vector databases",
    "Living Zettelkasten note graph with titles, tags, links, and FHRR similarity search",
    "Autonomous daily rewriting pass that cleans, merges, relinks, and retags notes",
    "Multi-channel messaging gateway supporting Telegram, WhatsApp, and Discord",
    "Three backend modes: Pi, Codex CLI, and local OpenAI-compatible models",
    "Proactive system with heartbeats, cron reminders, and scheduled memory reflection",
    "Pluggable skill registry with scoped triggers and backend adapters",
    "Promotion pipeline from graph notes to permanent MEMORY.md"
  ],
  "publicApiSurface": [
    "Nugget.remember(key, value, noteMeta?)",
    "Nugget.recall(query, sessionId?)",
    "Nugget.forget(key)",
    "Nugget.facts()",
    "Nugget.createNote(title, content, tags?, meta?)",
    "Nugget.editNote(noteId, newContent, updates?)",
    "Nugget.searchNotes(query, limit?, opts?)",
    "Nugget.addLink(note1, note2, reason)",
    "Nugget.mergeNotes(target, source, reason)",
    "Nugget.status()",
    "Nugget.save(path?)",
    "Nugget.load(path, opts?)",
    "NuggetShelf (multi-nugget manager)",
    "reflectAndCleanMemory(shelf, llmClient, opts?)",
    "promoteFacts(nugget, path?)",
    "nuggets remember <nugget> <key> <value>",
    "nuggets recall <query> [--nugget <name>]",
    "nuggets forget <nugget> <key>",
    "nuggets list",
    "nuggets facts <nugget>"
  ]
